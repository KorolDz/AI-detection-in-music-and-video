# Необязательная локальная конфигурация SQLite.
# Для итогового exe-приложения SQLite используется как безопасная локальная история проверок.
# Если путь не задан, приложение сохранит базу в профиле текущего пользователя.

# Пример:
# MEDIA_SECURITY_SQLITE_PATH=C:\Users\<user>\AppData\Local\MediaSecurity\history\scan_history.sqlite3
# MEDIA_SECURITY_TOOLS_DIR=H:\Detection\AI-detection-in-music-and-video\media_security\vendor\tools
# MEDIA_SECURITY_FFPROBE_PATH=H:\Detection\AI-detection-in-music-and-video\media_security\vendor\tools\windows\ffmpeg\bin\ffprobe.exe
# MEDIA_SECURITY_EXIFTOOL_PATH=H:\Detection\AI-detection-in-music-and-video\media_security\vendor\tools\windows\exiftool\exiftool.exe

MEDIA_SECURITY_SQLITE_PATH=
MEDIA_SECURITY_TOOLS_DIR=
MEDIA_SECURITY_FFPROBE_PATH=
MEDIA_SECURITY_EXIFTOOL_PATH=
